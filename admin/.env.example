# DONKEY API URL (프로덕션 빌드에서 절대 URL로 쏠 때만). 개발에서는 비우고 프록시 사용 권장(CORS 방지)
# 비우면: 개발 → /api + Vite 프록시, 프로덕션 → 같은 오리진 상대 경로
# VITE_API_BASE=https://donkey.ai.kr

# 개발 서버 전용: /api 가 프록시되는 백엔드 (기본 http://localhost:8000). 원격이면 예시처럼
# VITE_API_PROXY_TARGET=https://donkey.ai.kr

# STT 채점(Turing) API — https://turing.donkey.ai.kr , 헤더 X-API-Key
# 비우면 개발 시 Base는 /turing-api (Vite가 turing.donkey.ai.kr 로 프록시)
# VITE_TURING_API_BASE=https://turing.donkey.ai.kr
VITE_TURING_API_KEY=

# 개발 전용: UI만 볼 때 (로그인·API 없이). 프로덕션 빌드에서는 적용 안 됨
# VITE_DEV_PREVIEW=true
# VITE_DEV_PREVIEW_ROLE=admin
