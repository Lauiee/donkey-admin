# DONKEY API URL (로컬에서 원격 API 쓸 때 또는 분리 배포 시)
# 비우면 개발 시 Vite 프록시(/api → localhost:8000), 프로덕션은 상대 경로
# 예: https://donkey.ai.kr
VITE_API_BASE=

# STT 채점(Turing) API — https://turing.donkey.ai.kr , 헤더 X-API-Key
# 비우면 개발 시 Base는 /turing-api (Vite가 turing.donkey.ai.kr 로 프록시)
# VITE_TURING_API_BASE=https://turing.donkey.ai.kr
VITE_TURING_API_KEY=

# 개발 전용: UI만 볼 때 (로그인·API 없이). 프로덕션 빌드에서는 적용 안 됨
# VITE_DEV_PREVIEW=true
# VITE_DEV_PREVIEW_ROLE=admin
