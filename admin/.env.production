# 프로덕션 API Base URL (DONKEY 백엔드)
# 백엔드가 /api prefix 사용 시: https://donkey.ai.kr/api
VITE_API_BASE=https://donkey.ai.kr

# STT 채점(Turing) API — cnt 버전. (hippo 버전은 https://turing.donkey.ai.kr)
# 배포 환경(예: Vercel)에서 cntt.turing.intcorp.ai 가 외부에서 접근 가능한지 확인 필요.
# X-API-Key(VITE_TURING_API_KEY)는 비밀이므로 여기 두지 말고 배포 환경변수로 주입.
VITE_TURING_API_BASE=https://cntt.turing.intcorp.ai
