# 프로덕션 API Base URL (DONKEY 백엔드)
# 백엔드가 /api prefix 사용 시: https://donkey.ai.kr/api
VITE_API_BASE=https://donkey.ai.kr

# STT 채점(Turing) API — 도메인별 base URL
#   cnt   : https://cntt.turing.intcorp.ai
#   hippo : https://turing.donkey.ai.kr
# 배포 환경(예: Vercel)에서 두 백엔드가 외부에서 접근 가능한지 확인 필요.
# X-API-Key(VITE_TURING_API_KEY, VITE_TURING_API_KEY_HIPPO)는 비밀이므로 여기 두지 말고
# 배포 환경변수(Vercel Project Settings → Environment Variables)로 주입.
VITE_TURING_API_BASE=https://cntt.turing.intcorp.ai
VITE_TURING_API_BASE_HIPPO=https://turing.donkey.ai.kr
